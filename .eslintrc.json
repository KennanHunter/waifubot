{
	"extends": [
		"prettier",
		"eslint:recommended",
		"plugin:@typescript-eslint/recommended"
	],
	"plugins": ["prettier", "@typescript-eslint"],
	"rules": {
		"prettier/prettier": ["error"]
	},
	"env": {
		"serviceworker": true
	},
	"parserOptions": {
		"sourceType": "module",
		"ecmaVersion": "latest"
	},
	"ignorePatterns": ["node_modules"]
}
