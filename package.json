{
	"name": "waifubot",
	"version": "1.0.0",
	"description": "A simple discord bot that uses intents to post pictures from r/aww",
	"type": "module",
	"private": true,
	"main": "src/server.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/server.js",
		"dev": "wrangler dev dist/server.js",
		"ngrok": "ngrok http 8787",
