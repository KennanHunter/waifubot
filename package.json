	"license": "MIT",
	"dependencies": {
		"discord-interactions": "^3.2.0",
		"dotenv": "^16.0.1",
		"express": "^4.18.1",
		"itty-router": "^2.5.1",
		"node-fetch": "^3.2.2"
	},
	"devDependencies": {
		"c8": "^7.11.0",
		"eslint": "^8.9.0",
		"eslint-config-prettier": "^8.4.0",
		"eslint-plugin-prettier": "^4.0.0",
		"mocha": "^9.2.1",
		"ngrok": "^4.3.0",
		"prettier": "^2.5.1",
		"typescript": "^4.7.3",
		"wrangler": "^0.0.18"
